# I used this file for clear explanation of the project architecture and key technical decisions (10 mins video)



# for anyone trying to test the system, here are the steps to get it running and see the demo in action:


# 1. Start services:     docker compose up -d
# 2. Run migrations:     docker compose exec app npm run migrate
# 3. Seed test user:     docker compose exec app npm run seed
# 4. Run requests below to inspect the system behavior


@baseUrl = http://localhost:3000/api
@accessToken = {{login.response.body.accessToken}}
@refreshToken = {{login.response.body.refreshToken}}
@pipelineId = {{createPipeline.response.body.id}}
@sourceId = {{createPipeline.response.body.sourceId}}
@jobId = {{sendWebhook.response.body.id}}



###################################################
## AUTHENTICATION
###################################################


## LOGIN - Authenticate and receive JWT tokens
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@example.com",
    "password": "password123"
}



### REFRESH TOKEN - Get new access token without re-login
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
    "accessToken": "{{accessToken}}",
    "refreshToken": "{{refreshToken}}"
}



### Invalid credentials

POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@example.com",
    "password": "wrong-password"
}




###################################################
## PIPELINE
###################################################                                                                     


### CREATE PIPELINE - Full featured with all 3 action types
# @name createPipeline
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "E-Commerce Order Pipeline",
    "subscriberUrls": [
        "https://webhook.site/b5ca3aee-f45f-4f20-8503-d5b813906481"
    ],
    "actions": [
        {
            "actionType": "Validate",
            "configuration": "{\"requiredFields\": [\"orderId\", \"amount\"]}",
            "name": "Validate Order Data",
            "order": 0
        },
        {
            "actionType": "Transform",
            "configuration": "{\"trimStrings\": true, \"lowercaseFields\": [\"email\"], \"roundNumbers\": 2}",
            "name": "Normalize Order",
            "order": 1
        },
        {
            "actionType": "Enrich",
            "configuration": "{\"addTimestamp\": true, \"addHash\": \"orderId\", \"addUuid\": true}",
            "name": "Add Metadata",
            "order": 2
        }
    ]
}





### LIST ALL PIPELINES - owned by the authenticated user
GET {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}



### GET SINGLE PIPELINE
GET {{baseUrl}}/pipelines/{{pipelineId}}
Authorization: Bearer {{accessToken}}




### CREATE: Validation-only pipeline
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Data Validation Gate",
    "subscriberUrls": ["https://webhook.site/validation-only"],
    "actions": [
        {
            "actionType": "Validate",
            "configuration": "{\"requiredFields\": [\"id\", \"type\", \"data\"]}",
            "name": "Strict Schema Check",
            "order": 0
        }
    ]
}




### CREATE: Transform-only pipeline
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Data Cleanup Pipeline",
    "subscriberUrls": ["https://webhook.site/transform-only"],
    "actions": [
        {
            "actionType": "Transform",
            "configuration": "{\"trimStrings\": true, \"uppercaseFields\": [\"countryCode\"], \"lowercaseFields\": [\"email\"], \"removeNulls\": true}",
            "name": "Normalize & Clean",
            "order": 0
        }
    ]
}



### CREATE: Multi-subscriber fan-out pipeline
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Multi-Destination Fan-Out",
    "subscriberUrls": [
        "https://webhook.site/primary",
        "https://webhook.site/analytics",
        "https://webhook.site/backup"
    ],
    "actions": [
        {
            "actionType": "Enrich",
            "configuration": "{\"addTimestamp\": true, \"customFields\": {\"source\": \"webhook-pipeline\", \"version\": \"1.0\"}}",
            "name": "Add Routing Metadata",
            "order": 0
        }
    ]
}





### UPDATE PIPELINE
PUT {{baseUrl}}/pipelines/{{pipelineId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Updated Pipeline Name",
    "subscriberUrls": [
        "https://webhook.site/new-destination"
    ]
}



### DELETE PIPELINE
DELETE {{baseUrl}}/pipelines/{{pipelineId}}
Authorization: Bearer {{accessToken}}




###################################################
## WEBHOOK INGESTION
###################################################


### SEND WEBHOOK - Valid e-commerce order
# @name sendWebhook
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: demo-order-001

{
    "orderId": "ORD-2024-001",
    "amount": 149.9999,
    "email": "  CUSTOMER@EXAMPLE.COM  ",
    "status": "completed",
    "items": [
        {"name": "  Widget Pro  ", "quantity": 2, "price": 49.995},
        {"name": "  Gadget Plus  ", "quantity": 1, "price": 50.005}
    ]
}




### SEND WEBHOOK - Messy data (shows Transform in action)
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: messy-data-demo

{
    "orderId": "  MESSY-ORDER-001  ",
    "amount": 99.9999999,
    "email": "   MESSY.USER@EXAMPLE.COM   ",
    "status": "  pending  ",
    "price": 33.333333,
    "notes": "   Extra spaces everywhere   "
}




### SEND WEBHOOK - Missing required fields (will be FILTERED)
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: filtered-demo

{
    "description": "This order is missing required fields",
    "customerName": "John Doe"
}




### SEND WEBHOOK - Empty payload (will be FILTERED)
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: empty-payload-demo

{}





### IDEMPOTENCY TEST - Same key returns existing job
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: idempotency-test-key

{
    "orderId": "IDEM-001",
    "amount": 100
}





### IDEMPOTENCY TEST - Verify duplicate returns same job
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Idempotency-Key: idempotency-test-key

{
    "orderId": "IDEM-001",
    "amount": 100
}





### WEBHOOK WITH SIGNATURE VERIFICATION
POST {{baseUrl}}/webhooks/{{sourceId}}
Content-Type: application/json
X-Webhook-Signature: sha256=<computed-signature-here>
X-Idempotency-Key: signed-webhook-demo

{
    "orderId": "SIGNED-001",
    "amount": 250.00,
    "verified": true
}




###################################################
## JOB TRACKING
###################################################


### LIST ALL JOBS
GET {{baseUrl}}/jobs
Authorization: Bearer {{accessToken}}





### LIST JOBS - Paginated (page 1, 5 items)
GET {{baseUrl}}/jobs?page=1&pageSize=5
Authorization: Bearer {{accessToken}}





### LIST JOBS - Filter by status: Completed
GET {{baseUrl}}/jobs?status=Completed
Authorization: Bearer {{accessToken}}





### LIST JOBS - Filter by status: Filtered
GET {{baseUrl}}/jobs?status=Filtered
Authorization: Bearer {{accessToken}}





### LIST JOBS - Filter by status: Failed
GET {{baseUrl}}/jobs?status=Failed
Authorization: Bearer {{accessToken}}





### LIST JOBS - Filter by pipeline
GET {{baseUrl}}/jobs?pipelineId={{pipelineId}}
Authorization: Bearer {{accessToken}}





### GET JOB DETAILS
GET {{baseUrl}}/jobs/{{jobId}}
Authorization: Bearer {{accessToken}}





### GET JOB DELIVERIES
GET {{baseUrl}}/jobs/{{jobId}}/deliveries
Authorization: Bearer {{accessToken}}




###################################################
## SYSTEM HEALTH & METRICS
###################################################


### HEALTH CHECK
GET http://localhost:3000/





### PROMETHEUS METRICS
GET http://localhost:9464/metrics


###################################################
## ERROR HANDLING
###################################################


### ERROR: Unauthorized (no token)
GET {{baseUrl}}/pipelines





### ERROR: Invalid token
GET {{baseUrl}}/pipelines
Authorization: Bearer invalid-token-here

###

### ERROR: Pipeline not found
GET {{baseUrl}}/pipelines/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{accessToken}}





### ERROR: Webhook to non-existent pipeline
POST {{baseUrl}}/webhooks/nonexistent-source-id
Content-Type: application/json

{"test": "data"}





### ERROR: Invalid pipeline configuration
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Invalid Pipeline",
    "subscriberUrls": ["https://webhook.site/test"],
    "actions": [
        {
            "actionType": "NonExistentAction",
            "configuration": "{}",
            "order": 0
        }
    ]
}


###################################################
## COMPLETE WORKFLOW
###################################################


### STEP 1: Create a test pipeline
# @name demoPipeline
POST {{baseUrl}}/pipelines
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
    "name": "Video Demo Pipeline",
    "subscriberUrls": [
        "https://webhook.site/b5ca3aee-f45f-4f20-8503-d5b813906481"
    ],
    "actions": [
        {
            "actionType": "Validate",
            "configuration": "{\"requiredFields\": [\"eventType\", \"data\"]}",
            "name": "Validate Event Structure",
            "order": 0
        },
        {
            "actionType": "Transform",
            "configuration": "{\"trimStrings\": true, \"lowercaseFields\": [\"eventType\"]}",
            "name": "Normalize Event",
            "order": 1
        },
        {
            "actionType": "Enrich",
            "configuration": "{\"addTimestamp\": true, \"addUuid\": true, \"customFields\": {\"pipeline\": \"demo\", \"version\": \"1.0\"}}",
            "name": "Add Tracing Metadata",
            "order": 2
        }
    ]
}





### STEP 2: Send a webhook to the pipeline
@demoSourceId = {{demoPipeline.response.body.sourceId}}
# @name demoWebhook
POST {{baseUrl}}/webhooks/{{demoSourceId}}
Content-Type: application/json
X-Idempotency-Key: demo-video-{{$timestamp}}

{
    "eventType": "  ORDER.CREATED  ",
    "data": {
        "orderId": "  ORD-DEMO-001  ",
        "customerEmail": "demo@example.com",
        "total": 199.999,
        "currency": "USD"
    },
    "metadata": {
        "source": "  web-checkout  ",
        "sessionId": "sess_123456"
    }
}





### STEP 3: Check job status
@demoJobId = {{demoWebhook.response.body.id}}
GET {{baseUrl}}/jobs/{{demoJobId}}
Authorization: Bearer {{accessToken}}





### STEP 4: Check delivery status
GET {{baseUrl}}/jobs/{{demoJobId}}/deliveries
Authorization: Bearer {{accessToken}}





### STEP 5: View all jobs for the pipeline
@demoPipelineId = {{demoPipeline.response.body.id}}
GET {{baseUrl}}/jobs?pipelineId={{demoPipelineId}}
Authorization: Bearer {{accessToken}}



